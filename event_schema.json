{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WMFM ParsedEvent",
  "type": "object",
  "required": [
    "id",
    "code",
    "month",
    "date",
    "slot",
    "title",
    "start",
    "end",
    "tags",
    "dedupeKey",
    "source",
    "raw"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "UUID v4 or stable id"
    },
    "code": {
      "type": "string",
      "description": "roster code, e.g. 中"
    },
    "month": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}$",
      "description": "YYYY-MM"
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "YYYY-MM-DD"
    },
    "slot": {
      "type": "string",
      "enum": [
        "morning",
        "afternoon",
        "weekend",
        "clinic"
      ],
      "description": "time slot"
    },
    "title": {
      "type": "string"
    },
    "location": {
      "type": [
        "string",
        "null"
      ]
    },
    "start": {
      "type": "string",
      "description": "ISO 8601 local time, e.g. 2026-03-16T08:00:00"
    },
    "end": {
      "type": "string",
      "description": "ISO 8601 local time"
    },
    "timezone": {
      "type": "string",
      "default": "Asia/Taipei"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "must include #wmfm-schedule #code-<code> #YYYY-MM"
    },
    "dedupeKey": {
      "type": "string",
      "description": "stable hash for idempotent sync"
    },
    "taskLabel": {
      "type": [
        "string",
        "null"
      ],
      "description": "row label / column label"
    },
    "source": {
      "type": "object",
      "required": [
        "fileName",
        "sheetName",
        "cell"
      ],
      "properties": {
        "fileName": {
          "type": "string"
        },
        "sheetName": {
          "type": "string"
        },
        "cell": {
          "type": "string",
          "description": "A1 address"
        },
        "parserVersion": {
          "type": "string"
        }
      }
    },
    "raw": {
      "type": "string",
      "description": "raw cell text that triggered the event"
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}